@{
    ViewData["Title"] = "Quản lý lịch học";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-calendar3 me-2 text-primary"></i>Quản lý lịch học</h4>
    <a asp-action="Index" class="btn btn-primary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Về lịch học
    </a>
</div>

<div class="alert alert-info">
    <i class="bi bi-info-circle me-2"></i>
    Vui lòng sử dụng <a asp-action="Index" class="alert-link">trang lịch học</a> để quản lý và tạo lịch học.
</div>
