@model QuanLyKhoaHoc5.Web.Models.ViewModels.ProfileViewModel
@{ ViewData["Title"] = "Hồ sơ cá nhân"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-person-circle me-2 text-primary"></i>Hồ sơ cá nhân</h4>
    <a asp-controller="Account" asp-action="ChangePassword" class="btn btn-outline-warning"><i class="bi bi-key me-1"></i>Đổi mật khẩu</a>
</div>
<div class="row g-3">
    <div class="col-md-4">
        <div class="card text-center p-4">
            @if (!string.IsNullOrEmpty(Model.AnhDaiDien)) {
                <img src="@Model.AnhDaiDien" class="rounded-circle mx-auto mb-3" width="100" height="100" style="object-fit:cover" />
            } else {
                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3" style="width:100px;height:100px;font-size:2.5rem">@Model.HoTen.Substring(0,1)</div>
            }
            <h5 class="fw-bold">@Model.HoTen</h5>
            <p class="text-muted">@Model.Email</p>
            <span class="badge bg-primary fs-6">@Model.VaiTro</span>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header"><i class="bi bi-pencil me-2"></i>Cập nhật thông tin</div>
            <div class="card-body">
                <form method="post" asp-action="Edit" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="VaiTro" type="hidden" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="HoTen" class="form-label fw-semibold"></label>
                            <input asp-for="HoTen" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SoDienThoai" class="form-label fw-semibold"></label>
                            <input asp-for="SoDienThoai" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="AnhDaiDienFile" class="form-label fw-semibold">Ảnh đại diện</label>
                            <input asp-for="AnhDaiDienFile" class="form-control" type="file" accept=".jpg,.jpeg,.png" />
                            <small class="text-muted">Định dạng JPG, PNG. Tối đa 5MB.</small>
                        </div>

                        @if (Model.VaiTro == "HocVien") {
                            <div class="col-md-6">
                                <label asp-for="NgaySinh" class="form-label fw-semibold"></label>
                                <input asp-for="NgaySinh" class="form-control" type="date" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="GioiTinh" class="form-label fw-semibold"></label>
                                <select asp-for="GioiTinh" class="form-select">
                                    <option value="">-- Chọn --</option>
                                    <option>Nam</option><option>Nữ</option><option>Khác</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="TrinhDoHienTai" class="form-label fw-semibold"></label>
                                <select asp-for="TrinhDoHienTai" class="form-select">
                                    <option value="">-- Chọn --</option>
                                    <option>Sơ cấp</option><option>Trung cấp</option><option>Cao cấp</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NgonNguQuanTam" class="form-label fw-semibold"></label>
                                <select asp-for="NgonNguQuanTam" class="form-select">
                                    <option value="">-- Chọn --</option>
                                    <option>Tiếng Anh</option><option>Tiếng Nhật</option><option>Cả hai</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label asp-for="DiaChi" class="form-label fw-semibold"></label>
                                <input asp-for="DiaChi" class="form-control" />
                            </div>
                        }

                        @if (Model.VaiTro == "GiangVien") {
                            <div class="col-md-6">
                                <label asp-for="ChuyenMon" class="form-label fw-semibold"></label>
                                <select asp-for="ChuyenMon" class="form-select">
                                    <option value="">-- Chọn --</option>
                                    <option>Tiếng Anh</option><option>Tiếng Nhật</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="BangCap" class="form-label fw-semibold"></label>
                                <input asp-for="BangCap" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="KinhNghiem" class="form-label fw-semibold"></label>
                                <input asp-for="KinhNghiem" class="form-control" type="number" min="0" />
                            </div>
                            <div class="col-12">
                                <label asp-for="MoTa" class="form-label fw-semibold"></label>
                                <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                            </div>
                        }
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
