@model List<QuanLyKhoaHoc5.Web.Models.ViewModels.DiemCuaToiViewModel>
@{ ViewData["Title"] = "Điểm của tôi"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-bar-chart me-2 text-primary"></i>Điểm & Kết quả học tập</h4>
</div>
@if (Model.Any()) {
    <div class="row g-3">
        @foreach (var d in Model) {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <div>
                            <span class="fw-semibold">@d.TenLop</span><br/>
                            <small class="text-muted">@d.TenKhoaHoc</small>
                        </div>
                        <span class="badge @(d.NgonNgu=="Tiếng Anh"?"bg-primary":"bg-danger")">@d.NgonNgu</span>
                    </div>
                    <div class="card-body">
                        <div class="row text-center g-2 mb-3">
                            <div class="col-4">
                                <div class="border rounded p-2">
                                    <div class="fw-bold fs-5 text-info">@(d.DiemGiuaKy?.ToString("F1") ?? "-")</div>
                                    <div class="small text-muted">Giữa kỳ</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="border rounded p-2">
                                    <div class="fw-bold fs-5 text-warning">@(d.DiemCuoiKy?.ToString("F1") ?? "-")</div>
                                    <div class="small text-muted">Cuối kỳ</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="border rounded p-2 @(d.DiemTongKet >= 5 ? "border-success" : d.DiemTongKet.HasValue ? "border-danger" : "")">
                                    <div class="fw-bold fs-5 @(d.DiemTongKet >= 5 ? "text-success" : "text-muted")">@(d.DiemTongKet?.ToString("F1") ?? "-")</div>
                                    <div class="small text-muted">Tổng kết</div>
                                </div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(d.XepLoai)) {
                            var cls = d.XepLoai switch { "Xuất sắc" => "bg-success", "Giỏi" => "bg-primary", "Khá" => "bg-info", "Trung bình" => "bg-warning text-dark", _ => "bg-danger" };
                            <div class="text-center mb-2"><span class="badge @cls fs-6">@d.XepLoai</span></div>
                        }
                        @if (!string.IsNullOrEmpty(d.NhanXetGiangVien)) {
                            <div class="alert alert-light py-2 small"><i class="bi bi-chat-quote me-1"></i>@d.NhanXetGiangVien</div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
} else {
    <div class="text-center text-muted py-5">
        <i class="bi bi-bar-chart fs-1 d-block mb-3"></i>
        <p>Bạn chưa có điểm nào. Hãy đăng ký khóa học và hoàn thành để xem điểm.</p>
        <a asp-controller="KhoaHoc" asp-action="Index" class="btn btn-primary">Xem khóa học</a>
    </div>
}
