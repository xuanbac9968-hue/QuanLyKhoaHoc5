@model QuanLyKhoaHoc5.Web.Models.ViewModels.GiangVienCreateEditViewModel
@{
    ViewData["Title"] = "Thêm Giảng viên mới";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-person-plus me-2 text-primary"></i>Thêm Giảng viên mới</h4>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-person-workspace me-2"></i>Thông tin giảng viên
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="HoTen" class="form-label fw-semibold"></label>
                            <input asp-for="HoTen" class="form-control" placeholder="Nhập họ và tên đầy đủ" />
                            <span asp-validation-for="HoTen" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="example@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SoDienThoai" class="form-label fw-semibold"></label>
                            <input asp-for="SoDienThoai" class="form-control" placeholder="0xxxxxxxxx" />
                            <span asp-validation-for="SoDienThoai" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ChuyenMon" class="form-label fw-semibold"></label>
                            <select asp-for="ChuyenMon" class="form-select">
                                <option value="">-- Chọn chuyên môn --</option>
                                <option value="Tiếng Anh">Tiếng Anh</option>
                                <option value="Tiếng Nhật">Tiếng Nhật</option>
                            </select>
                            <span asp-validation-for="ChuyenMon" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BangCap" class="form-label fw-semibold"></label>
                            <input asp-for="BangCap" class="form-control" placeholder="VD: Thạc sĩ Ngôn ngữ Anh" />
                            <span asp-validation-for="BangCap" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="KinhNghiem" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="KinhNghiem" class="form-control" type="number" min="0" max="50" placeholder="0" />
                                <span class="input-group-text">năm</span>
                            </div>
                            <span asp-validation-for="KinhNghiem" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="MoTa" class="form-label fw-semibold"></label>
                            <textarea asp-for="MoTa" class="form-control" rows="4" placeholder="Mô tả về giảng viên, kinh nghiệm giảng dạy..."></textarea>
                            <span asp-validation-for="MoTa" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-circle me-1"></i>Lưu giảng viên
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
<script>
    document.querySelector('[data-valmsg-summary]')?.classList.remove('d-none');
    document.querySelector('form').addEventListener('submit', function() {
        var summary = document.querySelector('[data-valmsg-summary]');
        if (summary && summary.querySelector('li')) summary.classList.remove('d-none');
    });
</script>
}
