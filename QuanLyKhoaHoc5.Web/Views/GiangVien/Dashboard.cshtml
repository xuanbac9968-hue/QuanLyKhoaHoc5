@model QuanLyKhoaHoc5.Web.Models.ViewModels.GiangVienDashboardViewModel
@{
    ViewData["Title"] = "Dashboard Giảng viên";
}

<div class="mb-4">
    <h4 class="mb-1">
        <i class="bi bi-speedometer2 me-2 text-primary"></i>Xin chào, <strong>@Model.HoTen</strong>
    </h4>
    <p class="text-muted small mb-0">
        Mã GV: <code>@Model.MaGiangVien</code>
        @if (!string.IsNullOrEmpty(Model.ChuyenMon))
        {
            <span class="ms-2 badge bg-info-subtle text-info border border-info-subtle">@Model.ChuyenMon</span>
        }
    </p>
</div>

<!-- Stat cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card-primary">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="small opacity-75">Lớp đang dạy</div>
                    <div class="fs-2 fw-bold">@Model.LopDangDay.Count</div>
                </div>
                <i class="bi bi-door-open fs-2 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card-success">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="small opacity-75">Tổng học viên</div>
                    <div class="fs-2 fw-bold">@Model.SoHocVienTong</div>
                </div>
                <i class="bi bi-people fs-2 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card-warning">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="small opacity-75">Ca dạy hôm nay</div>
                    <div class="fs-2 fw-bold">@Model.LichHomNay.Count</div>
                </div>
                <i class="bi bi-calendar-check fs-2 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card-danger">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="small opacity-75">Thông báo chưa đọc</div>
                    <div class="fs-2 fw-bold">@Model.SoThongBaoChuaDoc</div>
                </div>
                <i class="bi bi-bell fs-2 opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Lịch hôm nay -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-calendar-day me-2 text-warning"></i>Lịch dạy hôm nay</span>
                <span class="badge bg-warning text-dark">@DateTime.Now.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="card-body p-0">
                @if (Model.LichHomNay.Count == 0)
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
                        Hôm nay không có lịch dạy
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr><th>Khóa học</th><th>Giờ</th><th>Phòng</th><th>Ca</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var lich in Model.LichHomNay)
                                {
                                    <tr>
                                        <td class="fw-semibold">@(lich.TenKhoaHoc ?? "-")</td>
                                        <td>
                                            <span class="badge bg-light text-dark border">
                                                @lich.GioBatDau.ToString("HH:mm") – @lich.GioKetThuc.ToString("HH:mm")
                                            </span>
                                        </td>
                                        <td>@(lich.PhongHoc ?? "—")</td>
                                        <td><span class="badge bg-primary">@lich.CaHoc</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Danh sách lớp đang dạy -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-door-open me-2 text-primary"></i>Lớp đang phụ trách</span>
                <a asp-controller="LopHoc" asp-action="Index" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                @if (Model.LopDangDay.Count == 0)
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        Chưa có lớp học nào
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr><th>Tên lớp</th><th>Khóa học</th><th class="text-center">Sĩ số</th><th class="text-center">Trạng thái</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var lop in Model.LopDangDay)
                                {
                                    <tr>
                                        <td>
                                            <a asp-controller="LopHoc" asp-action="Details" asp-route-id="@lop.Id" class="fw-semibold text-decoration-none">
                                                @lop.TenLop
                                            </a>
                                        </td>
                                        <td>
                                            <div class="small">@lop.TenKhoaHoc</div>
                                            <span class="badge bg-info-subtle text-info border border-info-subtle small">@lop.NgonNgu</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="small">@lop.SiSoHienTai / @lop.SiSoToiDa</span>
                                        </td>
                                        <td class="text-center">
                                            @{
                                                var badgeLop = lop.TrangThai switch {
                                                    "DangHoc" => "bg-success",
                                                    "DangTuyenSinh" => "bg-primary",
                                                    "DaKetThuc" => "bg-secondary",
                                                    "ChuaMo" => "bg-warning text-dark",
                                                    _ => "bg-warning text-dark"
                                                };
                                                var tenLop = lop.TrangThai switch {
                                                    "DangHoc" => "Đang học",
                                                    "DangTuyenSinh" => "Đang tuyển sinh",
                                                    "DaKetThuc" => "Đã kết thúc",
                                                    "ChuaMo" => "Chưa mở",
                                                    _ => lop.TrangThai
                                                };
                                            }
                                            <span class="badge @badgeLop">@tenLop</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Lịch tuần -->
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-calendar3-week me-2 text-success"></i>Lịch dạy tuần (mẫu)</span>
                <a asp-controller="GiangVien" asp-action="LichDay" class="btn btn-sm btn-outline-success">Xem chi tiết</a>
            </div>
            <div class="card-body">
                @if (Model.LichTuanNay.Count == 0)
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-calendar2-x fs-1 d-block mb-2"></i>
                        Chưa được phân công lịch dạy nào
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var item in Model.LichTuanNay.OrderBy(l => l.NgayHoc).ThenBy(l => l.GioBatDau))
                        {
                            <div class="list-group-item d-flex align-items-center gap-3 px-0">
                                <div class="text-center rounded" style="min-width:56px;background:#f0f2f5;padding:.4rem .3rem;">
                                    <div class="fs-6 fw-bold text-primary">@item.TenThu</div>
                                    <div class="small text-muted" style="font-size:.7rem;">@item.CaHoc</div>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold">@(item.TenKhoaHoc ?? "-")</div>
                                    <div class="small text-muted">
                                        <i class="bi bi-clock me-1"></i>@item.GioBatDau.ToString("HH:mm") – @item.GioKetThuc.ToString("HH:mm")
                                        @if (!string.IsNullOrEmpty(item.PhongHoc))
                                        {
                                            <span class="ms-2"><i class="bi bi-geo-alt me-1"></i>@item.PhongHoc</span>
                                        }
                                    </div>
                                </div>
                                <span class="badge bg-success">Đang dạy</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
