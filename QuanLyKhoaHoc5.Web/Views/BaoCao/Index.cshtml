@{
    ViewData["Title"] = "Báo cáo tổng hợp";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-file-earmark-bar-graph me-2 text-primary"></i>Báo cáo tổng hợp</h4>
    <a asp-action="ExportTongHop" class="btn btn-success">
        <i class="bi bi-file-earmark-excel me-1"></i>Xuất Excel tổng hợp
    </a>
</div>

<!-- 4 số liệu tổng hợp -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-primary">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TongHocVien</div>
                    <div class="small opacity-75">Tổng học viên</div>
                </div>
                <i class="bi bi-people-fill fs-2 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-success">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TongGiangVien</div>
                    <div class="small opacity-75">Tổng giảng viên</div>
                </div>
                <i class="bi bi-person-workspace fs-2 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-warning">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TongKhoaHoc</div>
                    <div class="small opacity-75">Tổng khóa học</div>
                </div>
                <i class="bi bi-book-fill fs-2 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-danger">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TongLopKetThuc</div>
                    <div class="small opacity-75">Lớp đã kết thúc</div>
                </div>
                <i class="bi bi-check-circle-fill fs-2 opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<!-- Biểu đồ đăng ký theo tháng -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-bar-chart-line me-2 text-primary"></i>Số học viên đăng ký theo tháng (năm @DateTime.Now.Year)</span>
    </div>
    <div class="card-body">
        <canvas id="chartDangKy" height="80"></canvas>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
var labels = @Html.Raw(ViewBag.ChartLabels);
var data   = @Html.Raw(ViewBag.ChartData);
new Chart(document.getElementById('chartDangKy'), {
    type: 'bar',
    data: {
        labels: labels,
        datasets: [{
            label: 'Số đăng ký',
            data: data,
            backgroundColor: 'rgba(13,110,253,.6)',
            borderColor: '#0d6efd',
            borderWidth: 1,
            borderRadius: 6
        }]
    },
    options: {
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
    }
});
</script>
}
