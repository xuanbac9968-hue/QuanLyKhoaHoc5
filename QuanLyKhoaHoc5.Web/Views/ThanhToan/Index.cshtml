@model QuanLyKhoaHoc5.Web.Models.ViewModels.AdminThanhToanFilterViewModel
@{
    ViewData["Title"] = "Quản lý thanh toán";
    decimal tongThuThang = ViewBag.TongThuThang ?? 0m;
    int thang = ViewBag.Thang ?? DateTime.Now.Month;
    int nam = ViewBag.Nam ?? DateTime.Now.Year;
    int soChoPheduyet = ViewBag.SoChoPheduyet ?? 0;
    int totalPages = (int)Math.Ceiling((double)Model.TotalItems / Model.PageSize);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-credit-card me-2 text-primary"></i>Quản lý thanh toán học phí</h4>
</div>

<!-- Stat cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card text-bg-success shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <div class="fs-4 fw-bold">@tongThuThang.ToString("N0") đ</div>
                    <div class="small opacity-75">Tổng thu tháng @thang/@nam</div>
                </div>
                <i class="bi bi-cash-stack fs-2 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-bg-warning shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <div class="fs-4 fw-bold">@soChoPheduyet</div>
                    <div class="small opacity-75">Yêu cầu chờ phê duyệt</div>
                </div>
                <i class="bi bi-hourglass-split fs-2 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-bg-primary shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <div class="fs-4 fw-bold">@Model.TotalItems</div>
                    <div class="small opacity-75">Tổng yêu cầu @(Model.TrangThai != null ? "(" + Model.TrangThai + ")" : "")</div>
                </div>
                <i class="bi bi-list-check fs-2 opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<!-- Filter -->
<div class="card mb-3 shadow-sm">
    <div class="card-body py-2 px-3">
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="text-muted small fw-semibold"><i class="bi bi-funnel me-1"></i>Lọc:</span>
            <a href="@Url.Action("Index")"
               class="btn btn-sm @(Model.TrangThai == null ? "btn-primary" : "btn-outline-secondary")">Tất cả</a>
            <a href="@Url.Action("Index", new { trangThai = "ChoPheduyet" })"
               class="btn btn-sm @(Model.TrangThai == "ChoPheduyet" ? "btn-warning text-dark" : "btn-outline-warning")">
                <i class="bi bi-hourglass-split me-1"></i>Chờ duyệt
            </a>
            <a href="@Url.Action("Index", new { trangThai = "DaThanhToan" })"
               class="btn btn-sm @(Model.TrangThai == "DaThanhToan" ? "btn-success" : "btn-outline-success")">
                <i class="bi bi-check-circle me-1"></i>Đã thanh toán
            </a>
            <a href="@Url.Action("Index", new { trangThai = "TuChoi" })"
               class="btn btn-sm @(Model.TrangThai == "TuChoi" ? "btn-danger" : "btn-outline-danger")">
                <i class="bi bi-x-circle me-1"></i>Từ chối
            </a>
        </div>
    </div>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-inbox fs-2 d-block mb-2"></i>
        Không có yêu cầu thanh toán nào.
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Học viên</th>
                            <th>Khóa học</th>
                            <th class="text-end">Số tiền</th>
                            <th class="text-center">Phương thức</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center">Ngày tạo</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int stt = (Model.Page - 1) * Model.PageSize + 1; }
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="text-muted small">@(stt++)</td>
                                <td>
                                    <div class="fw-semibold">@item.TenHocVien</div>
                                    <small class="text-muted">@item.MaHocVien</small>
                                </td>
                                <td>@item.TenKhoaHoc</td>
                                <td class="text-end fw-semibold text-success">@item.SoTien.ToString("N0") đ</td>
                                <td class="text-center">
                                    <span class="badge @(item.PhuongThuc == "ChuyenKhoan" ? "bg-info text-dark" : "bg-secondary")">
                                        @(item.PhuongThuc == "ChuyenKhoan" ? "Chuyển khoản" : "Tiền mặt")
                                    </span>
                                </td>
                                <td class="text-center">
                                    @{
                                        var (cls, txt) = item.TrangThai switch
                                        {
                                            "ChoPheduyet" => ("bg-warning text-dark", "Chờ phê duyệt"),
                                            "DaThanhToan"  => ("bg-success", "Đã thanh toán"),
                                            "TuChoi"       => ("bg-danger", "Từ chối"),
                                            _              => ("bg-secondary", item.TrangThai)
                                        };
                                    }
                                    <span class="badge @cls">@txt</span>
                                </td>
                                <td class="text-center small text-muted">@item.NgayTao.ToString("dd/MM/yyyy")</td>
                                <td class="text-center">
                                    <a asp-action="ChiTiet" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i>Chi tiết
                                    </a>
                                    @if (item.TrangThai == "ChoPheduyet")
                                    {
                                        <button type="button" class="btn btn-sm btn-success ms-1"
                                                onclick="duyetNhanh(@item.Id, 'DaThanhToan')">
                                            <i class="bi bi-check"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-danger ms-1"
                                                onclick="duyetNhanh(@item.Id, 'TuChoi')">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (totalPages > 1)
        {
            <div class="card-footer">
                <nav>
                    <ul class="pagination pagination-sm mb-0 justify-content-center">
                        @for (int p = 1; p <= totalPages; p++)
                        {
                            <li class="page-item @(p == Model.Page ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { trangThai = Model.TrangThai, page = p })">@p</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
}

<!-- Modal duyệt nhanh -->
<div class="modal fade" id="modalDuyet" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header"><h6 class="modal-title">Xác nhận</h6></div>
            <div class="modal-body">
                <p id="modalDuyetText" class="mb-2"></p>
                <form id="formDuyet" method="post" asp-action="Duyet">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="duyetId" name="Id" />
                    <input type="hidden" id="duyetHanhDong" name="HanhDong" />
                    <div class="mb-2">
                        <label class="form-label small">Ghi chú (không bắt buộc)</label>
                        <textarea name="GhiChu" class="form-control form-control-sm" rows="2"></textarea>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" id="btnDuyetSubmit" class="btn btn-sm btn-primary">Xác nhận</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function duyetNhanh(id, hanhDong) {
    document.getElementById('duyetId').value = id;
    document.getElementById('duyetHanhDong').value = hanhDong;
    var text = hanhDong === 'DaThanhToan' ? 'Xác nhận thanh toán thành công?' : 'Từ chối yêu cầu này?';
    document.getElementById('modalDuyetText').textContent = text;
    var btn = document.getElementById('btnDuyetSubmit');
    btn.className = hanhDong === 'DaThanhToan' ? 'btn btn-sm btn-success' : 'btn btn-sm btn-danger';
    btn.textContent = hanhDong === 'DaThanhToan' ? 'Xác nhận' : 'Từ chối';
    new bootstrap.Modal(document.getElementById('modalDuyet')).show();
}
</script>
}
