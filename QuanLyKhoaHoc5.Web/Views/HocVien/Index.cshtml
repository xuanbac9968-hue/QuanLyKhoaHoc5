@model List<QuanLyKhoaHoc5.Web.Models.ViewModels.HocVienListViewModel>
@{ ViewData["Title"] = "Quản lý Học viên"; int page = (int)(ViewBag.Page ?? 1); int totalPages = (int)(ViewBag.TotalPages ?? 1); }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-people me-2 text-primary"></i>Quản lý Học viên</h4>
    <div class="d-flex gap-2">
        <a asp-action="ExportExcel" class="btn btn-success"><i class="bi bi-file-earmark-excel me-1"></i>Xuất Excel</a>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Thêm học viên</a>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-6">
                <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm theo tên, mã HV, email..." />
            </div>
            <div class="col-auto"><button type="submit" class="btn btn-outline-primary"><i class="bi bi-search me-1"></i>Tìm</button></div>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string)) {
                <div class="col-auto"><a asp-action="Index" class="btn btn-outline-secondary">Xóa filter</a></div>
            }
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã HV</th><th>Họ tên</th><th>Email</th>
                        <th>Trình độ</th><th>Ngôn ngữ</th><th>KH đã đăng ký</th>
                        <th>Trạng thái</th><th>Ngày đăng ký</th><th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var hv in Model)
                {
                    <tr>
                        <td class="fw-semibold text-primary">@hv.MaHocVien</td>
                        <td>@hv.HoTen</td>
                        <td class="small text-muted">@hv.Email</td>
                        <td><span class="badge bg-info text-dark">@(hv.TrinhDoHienTai ?? "-")</span></td>
                        <td class="small">@(hv.NgonNguQuanTam ?? "-")</td>
                        <td class="text-center"><span class="badge bg-secondary">@hv.SoKhoaDaDangKy</span></td>
                        <td>
                            @if (hv.IsActive) { <span class="badge bg-success">Hoạt động</span> }
                            else { <span class="badge bg-danger">Đã khóa</span> }
                        </td>
                        <td class="small text-muted">@hv.NgayDangKy.ToString("dd/MM/yyyy")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@hv.Id" class="btn btn-sm btn-outline-info" title="Chi tiết"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@hv.Id" class="btn btn-sm btn-outline-warning" title="Sửa"><i class="bi bi-pencil"></i></a>
                                <form method="post" asp-action="Delete" asp-route-id="@hv.Id" onsubmit="return confirm('Vô hiệu hóa học viên này?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Vô hiệu hóa"><i class="bi bi-person-x"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any()) {
                    <tr><td colspan="9" class="text-center text-muted py-4">Không có học viên nào</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    @if (totalPages > 1) {
        <div class="card-footer">
            <nav><ul class="pagination pagination-sm mb-0 justify-content-center">
                @for (int i = 1; i <= totalPages; i++) {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@ViewBag.Search">@i</a>
                    </li>
                }
            </ul></nav>
        </div>
    }
</div>
