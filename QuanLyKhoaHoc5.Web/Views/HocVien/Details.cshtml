@model QuanLyKhoaHoc5.Web.Models.ViewModels.HocVienDetailsViewModel
@{ ViewData["Title"] = "Chi tiết học viên"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-person-circle me-2 text-primary"></i>Chi tiết học viên</h4>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Sửa</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
    </div>
</div>
<div class="row g-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center p-4">
                @if (!string.IsNullOrEmpty(Model.AnhDaiDien)) {
                    <img src="@Model.AnhDaiDien" class="rounded-circle mb-3" width="80" height="80" style="object-fit:cover" />
                } else {
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3" style="width:80px;height:80px;font-size:2rem">@Model.HoTen.Substring(0,1)</div>
                }
                <h5 class="fw-bold">@Model.HoTen</h5>
                <span class="badge bg-primary">@Model.MaHocVien</span>
                @if (Model.IsActive) { <br/><span class="badge bg-success mt-1">Hoạt động</span> }
                else { <br/><span class="badge bg-danger mt-1">Đã khóa</span> }
            </div>
            <div class="list-group list-group-flush">
                <div class="list-group-item"><i class="bi bi-envelope text-muted me-2"></i>@Model.Email</div>
                @if (!string.IsNullOrEmpty(Model.SoDienThoai)) { <div class="list-group-item"><i class="bi bi-phone text-muted me-2"></i>@Model.SoDienThoai</div> }
                @if (Model.NgaySinh.HasValue) { <div class="list-group-item"><i class="bi bi-cake text-muted me-2"></i>@Model.NgaySinh.Value.ToString("dd/MM/yyyy")</div> }
                @if (!string.IsNullOrEmpty(Model.GioiTinh)) { <div class="list-group-item"><i class="bi bi-gender-ambiguous text-muted me-2"></i>@Model.GioiTinh</div> }
                @if (!string.IsNullOrEmpty(Model.DiaChi)) { <div class="list-group-item"><i class="bi bi-geo-alt text-muted me-2"></i>@Model.DiaChi</div> }
                @if (!string.IsNullOrEmpty(Model.TrinhDoHienTai)) { <div class="list-group-item"><i class="bi bi-award text-muted me-2"></i>Trình độ: @Model.TrinhDoHienTai</div> }
                @if (!string.IsNullOrEmpty(Model.NgonNguQuanTam)) { <div class="list-group-item"><i class="bi bi-translate text-muted me-2"></i>Ngôn ngữ: @Model.NgonNguQuanTam</div> }
                <div class="list-group-item"><i class="bi bi-calendar text-muted me-2"></i>Ngày đăng ký: @Model.NgayDangKy.ToString("dd/MM/yyyy")</div>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header"><i class="bi bi-clipboard-check me-2 text-primary"></i>Lịch sử đăng ký khóa học</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light"><tr><th>Lớp học</th><th>Khóa học</th><th>Ngôn ngữ</th><th>Ngày DK</th><th>Trạng thái</th><th>Điểm TK</th></tr></thead>
                        <tbody>
                        @foreach (var d in Model.LichSuDangKy)
                        {
                            <tr>
                                <td class="fw-semibold">@d.TenLop</td>
                                <td class="small">@d.TenKhoaHoc</td>
                                <td><span class="badge @(d.NgonNgu=="Tiếng Anh"?"bg-primary":"bg-danger")">@d.NgonNgu</span></td>
                                <td class="small text-muted">@d.NgayDangKy.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @switch (d.TrangThai) {
                                        case "DaDuyet": <span class="badge bg-success">Đã duyệt</span>; break;
                                        case "ChoDuyet": <span class="badge bg-warning text-dark">Chờ duyệt</span>; break;
                                        case "TuChoi": <span class="badge bg-danger" title="@d.LyDoTuChoi">Từ chối</span>; break;
                                        case "DaHuy": <span class="badge bg-secondary">Đã hủy</span>; break;
                                        default: <span class="badge bg-secondary">@d.TrangThai</span>; break;
                                    }
                                </td>
                                <td>@(d.DiemTongKet.HasValue ? d.DiemTongKet.Value.ToString("F1") + " - " + d.XepLoai : "-")</td>
                            </tr>
                        }
                        @if (!Model.LichSuDangKy.Any()) { <tr><td colspan="6" class="text-center text-muted py-3">Chưa có đăng ký nào</td></tr> }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
