@model QuanLyKhoaHoc5.Web.Models.ViewModels.HocVienDashboardViewModel
@{ ViewData["Title"] = "Dashboard Học viên"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-speedometer2 me-2 text-primary"></i>Xin chào, @Model.HoTen!</h4>
    <span class="text-muted small">@DateTime.Now.ToString("dddd, dd/MM/yyyy")</span>
</div>

<!-- Profile + Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center p-4">
                @if (!string.IsNullOrEmpty(Model.AnhDaiDien))
                {
                    <img src="@Model.AnhDaiDien" class="rounded-circle mb-3" width="80" height="80" style="object-fit:cover" alt="avatar" />
                }
                else
                {
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3" style="width:80px;height:80px;font-size:2rem">
                        @Model.HoTen.Substring(0,1)
                    </div>
                }
                <h5 class="fw-bold mb-1">@Model.HoTen</h5>
                <span class="badge bg-primary mb-2">@Model.MaHocVien</span>
                <div class="text-muted small">
                    @if (!string.IsNullOrEmpty(Model.TrinhDoHienTai)) { <div><i class="bi bi-award me-1"></i>@Model.TrinhDoHienTai</div> }
                    @if (!string.IsNullOrEmpty(Model.NgonNguQuanTam)) { <div><i class="bi bi-translate me-1"></i>@Model.NgonNguQuanTam</div> }
                </div>
                <a asp-controller="Profile" asp-action="Index" class="btn btn-sm btn-outline-primary mt-3 w-100">Chỉnh sửa hồ sơ</a>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="row g-3">
            <div class="col-6">
                <div class="stat-card stat-card-primary">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fs-3 fw-bold">@Model.KhoaHocDangHoc.Count</div>
                            <div class="small opacity-75">Khóa đang học</div>
                        </div>
                        <i class="bi bi-book-fill fs-2 opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-6">
                <div class="stat-card stat-card-success">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fs-3 fw-bold">@Model.LichHocTuanNay.Count</div>
                            <div class="small opacity-75">Buổi học tuần này</div>
                        </div>
                        <i class="bi bi-calendar-check-fill fs-2 opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <!-- AI Gợi ý nổi bật -->
                @if (Model.GoiYGanNhat.Any())
                {
                    <div class="card border-0" style="background:linear-gradient(135deg,#fff3cd,#fff)">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-semibold"><i class="bi bi-stars text-warning me-1"></i>AI gợi ý cho bạn</span>
                                <a asp-controller="GoiY" asp-action="Index" class="btn btn-sm btn-warning">Xem thêm</a>
                            </div>
                            @foreach (var g in Model.GoiYGanNhat.Take(2))
                            {
                                <div class="d-flex justify-content-between align-items-center py-1 border-bottom">
                                    <div>
                                        <span class="fw-semibold small">@g.TenKhoaHoc</span><br/>
                                        <span class="text-muted" style="font-size:.75rem">@g.LyDo</span>
                                    </div>
                                    <span class="badge bg-warning text-dark">@g.DiemPhuHop.ToString("F0")%</span>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="card border-warning border-dashed">
                        <div class="card-body text-center py-3">
                            <i class="bi bi-stars text-warning fs-3"></i>
                            <p class="mb-2 small">Nhận gợi ý khóa học phù hợp từ AI</p>
                            <a asp-controller="GoiY" asp-action="Index" class="btn btn-sm btn-warning">Nhận gợi ý ngay</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Khóa học đang học -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between">
                <span><i class="bi bi-book me-2 text-primary"></i>Khóa học đang theo học</span>
                <a asp-controller="DangKy" asp-action="CuaToi" class="btn btn-sm btn-outline-primary">Quản lý đăng ký</a>
            </div>
            <div class="card-body p-0">
                @if (Model.KhoaHocDangHoc.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var k in Model.KhoaHocDangHoc)
                        {
                            <a asp-controller="KhoaHoc" asp-action="Details" asp-route-id="@k.KhoaHocId"
                               class="list-group-item list-group-item-action">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-semibold small">@k.TenLop</div>
                                        <div class="text-muted" style="font-size:.75rem">@k.TenKhoaHoc · @k.NgonNgu</div>
                                    </div>
                                    @if (k.DiemTongKet.HasValue)
                                    {
                                        <span class="badge bg-success">@k.DiemTongKet.Value.ToString("F1")</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">Đang học</span>
                                    }
                                </div>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-book fs-3 d-block mb-2"></i>
                        Bạn chưa đăng ký khóa học nào.<br/>
                        <a asp-controller="KhoaHoc" asp-action="Index" class="btn btn-sm btn-primary mt-2">Xem khóa học</a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Lịch học tuần này -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between">
                <span><i class="bi bi-calendar3 me-2 text-primary"></i>Lịch học tuần này</span>
                <a asp-controller="LichHoc" asp-action="CuaToi" class="btn btn-sm btn-outline-primary">Xem đầy đủ</a>
            </div>
            <div class="card-body p-0">
                @if (Model.LichHocTuanNay.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var l in Model.LichHocTuanNay)
                        {
                            var caColor = l.CaHoc switch {
                                "Sáng" => "#3b82f6",
                                "Chiều" => "#f97316",
                                "Tối" => "#8b5cf6",
                                _ => "#0d6efd"
                            };
                            <div class="list-group-item">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="text-center text-white rounded p-1" style="min-width:58px;background:@caColor">
                                        <div style="font-size:.6rem;opacity:.9">@l.TenThu</div>
                                        <div class="fw-bold" style="font-size:.85rem">@l.NgayHoc.ToString("dd/MM")</div>
                                        <div style="font-size:.6rem;opacity:.85">@l.CaHoc</div>
                                    </div>
                                    <div>
                                        <div class="small fw-semibold">@(l.TenKhoaHoc ?? "-")</div>
                                        <div class="text-muted" style="font-size:.75rem">
                                            <i class="bi bi-clock me-1"></i>@l.GioBatDau.ToString("HH:mm") – @l.GioKetThuc.ToString("HH:mm")
                                            @if (!string.IsNullOrEmpty(l.PhongHoc)) { <span class="ms-1"><i class="bi bi-geo-alt me-1"></i>@l.PhongHoc</span> }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-calendar-x fs-3 d-block mb-2"></i>Không có lịch học tuần này
                    </div>
                }
            </div>
        </div>
    </div>
</div>
