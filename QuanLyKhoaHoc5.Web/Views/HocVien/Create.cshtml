@model QuanLyKhoaHoc5.Web.Models.ViewModels.HocVienCreateEditViewModel
@{ ViewData["Title"] = "Thêm học viên mới"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-person-plus me-2 text-primary"></i>Thêm học viên mới</h4>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>
<div class="card">
    <div class="card-body">
        <form method="post" asp-action="Create">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="HoTen" class="form-label fw-semibold"></label>
                    <input asp-for="HoTen" class="form-control" placeholder="Nguyễn Văn A" />
                    <span asp-validation-for="HoTen" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" class="form-control" placeholder="email@gmail.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="SoDienThoai" class="form-label fw-semibold"></label>
                    <input asp-for="SoDienThoai" class="form-control" placeholder="0912345678" />
                </div>
                <div class="col-md-6">
                    <label asp-for="NgaySinh" class="form-label fw-semibold"></label>
                    <input asp-for="NgaySinh" class="form-control" type="date" />
                </div>
                <div class="col-md-4">
                    <label asp-for="GioiTinh" class="form-label fw-semibold"></label>
                    <select asp-for="GioiTinh" class="form-select">
                        <option value="">-- Chọn --</option>
                        <option value="Nam">Nam</option>
                        <option value="Nữ">Nữ</option>
                        <option value="Khác">Khác</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="TrinhDoHienTai" class="form-label fw-semibold"></label>
                    <select asp-for="TrinhDoHienTai" class="form-select">
                        <option value="">-- Chọn --</option>
                        <option>Sơ cấp</option><option>Trung cấp</option><option>Cao cấp</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="NgonNguQuanTam" class="form-label fw-semibold"></label>
                    <select asp-for="NgonNguQuanTam" class="form-select">
                        <option value="">-- Chọn --</option>
                        <option>Tiếng Anh</option><option>Tiếng Nhật</option><option>Cả hai</option>
                    </select>
                </div>
                <div class="col-12">
                    <label asp-for="DiaChi" class="form-label fw-semibold"></label>
                    <input asp-for="DiaChi" class="form-control" placeholder="Địa chỉ..." />
                </div>
                <div class="col-12">
                    <label asp-for="GhiChu" class="form-label fw-semibold"></label>
                    <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <div class="alert alert-info mt-3 py-2 small"><i class="bi bi-info-circle me-1"></i>Mật khẩu mặc định sẽ được tạo tự động theo cấu hình hệ thống.</div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Lưu học viên</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Hủy</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
