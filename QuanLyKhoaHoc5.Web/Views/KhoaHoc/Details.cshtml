@model QuanLyKhoaHoc5.Web.Models.Entities.KhoaHoc
@using QuanLyKhoaHoc5.Web.Models.Entities
@using QuanLyKhoaHoc5.Web.Models.ViewModels
@{
    ViewData["Title"] = Model.TenKhoaHoc;
    var isAdmin = User.IsInRole("Admin");
    var isHocVien = User.IsInRole("HocVien");
    bool daDangKy = ViewBag.DaDangKy ?? false;
    bool coChoTrong = ViewBag.CoChoTrong ?? false;
    int soHvDaDk = ViewBag.SoHvDaDk ?? 0;
    int? lopMoId = ViewBag.LopMoId;
    var lichHocList = ViewBag.LichHocList as List<QuanLyKhoaHoc5.Web.Models.ViewModels.LichHocChiTietViewModel> ?? [];
    var badgeClass = Model.TrangThai switch
    {
        "DangMo" => "bg-success",
        "DaDong" => "bg-danger",
        "TamDung" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
    var trangThaiText = Model.TrangThai switch
    {
        "DangMo" => "Đang mở",
        "DaDong" => "Đã đóng",
        "TamDung" => "Tạm dừng",
        _ => Model.TrangThai
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-action="Index">Khóa học</a></li>
            <li class="breadcrumb-item active">@Model.TenKhoaHoc</li>
        </ol>
    </nav>
    @if (isAdmin)
    {
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
                <i class="bi bi-pencil me-1"></i>Sửa
            </a>
            <a asp-controller="LichHoc" asp-action="Index" asp-route-khoaHocId="@Model.Id" class="btn btn-info btn-sm text-white">
                <i class="bi bi-calendar3 me-1"></i>Quản lý lịch
            </a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm('Bạn có chắc muốn xóa khóa học này?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger btn-sm">
                    <i class="bi bi-trash me-1"></i>Xóa
                </button>
            </form>
        </div>
    }
</div>

<div class="row g-4">
    <div class="col-md-4">
        @if (!string.IsNullOrEmpty(Model.AnhBia))
        {
            <img src="@Model.AnhBia" alt="@Model.TenKhoaHoc" class="img-fluid rounded shadow-sm mb-3" />
        }
        else
        {
            <div class="bg-light rounded d-flex align-items-center justify-content-center mb-3" style="height:220px;">
                <i class="bi bi-book fs-1 text-secondary"></i>
            </div>
        }

        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white fw-bold">
                <i class="bi bi-info-circle me-1"></i>Thông tin khóa học
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Ngôn ngữ</span>
                    <span class="badge bg-info text-dark">@Model.NgonNgu</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Trình độ</span>
                    <strong>@Model.TrinhDo</strong>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Học phí</span>
                    <strong class="text-primary">@Model.HocPhi.ToString("N0") VNĐ</strong>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Số buổi học</span>
                    <strong>@Model.ThoiLuong buổi</strong>
                </li>
                @if (Model.SoBuoiMoiTuan.HasValue)
                {
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Lịch học</span>
                        <strong>@Model.SoBuoiMoiTuan buổi/tuần</strong>
                    </li>
                }
                @if (Model.ThoiGianMoiBuoi.HasValue)
                {
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Thời gian/buổi</span>
                        <strong>@Model.ThoiGianMoiBuoi phút</strong>
                    </li>
                }
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Chỗ còn trống</span>
                    <strong class="@(coChoTrong ? "text-success" : "text-danger")">
                        @(Model.SoChoToiDa - soHvDaDk) / @Model.SoChoToiDa
                    </strong>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Trạng thái</span>
                    <span class="badge @badgeClass">@trangThaiText</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-muted">Ngày tạo</span>
                    <span>@Model.NgayTao.ToString("dd/MM/yyyy")</span>
                </li>
            </ul>
        </div>

        @if (isHocVien && lopMoId.HasValue)
        {
            <div class="mt-3">
                @if (daDangKy)
                {
                    <button class="btn btn-secondary w-100" disabled>
                        <i class="bi bi-check-circle me-1"></i>Đã đăng ký
                    </button>
                }
                else if (!coChoTrong)
                {
                    <button class="btn btn-secondary w-100" disabled>
                        <i class="bi bi-x-circle me-1"></i>Hết chỗ
                    </button>
                }
                else
                {
                    <a asp-controller="DangKy" asp-action="DangKy" asp-route-lopHocId="@lopMoId" class="btn btn-success w-100 btn-lg">
                        <i class="bi bi-check2-circle me-1"></i>Đăng ký ngay
                    </a>
                }
            </div>
        }
    </div>

    <div class="col-md-8">
        <h2 class="fw-bold">@Model.TenKhoaHoc</h2>

        @if (!string.IsNullOrEmpty(Model.MoTa))
        {
            <div class="mb-4">
                <h5 class="fw-semibold"><i class="bi bi-card-text me-2"></i>Mô tả</h5>
                <p class="text-muted">@Model.MoTa</p>
            </div>
        }

        <!-- Upcoming sessions -->
        @if (lichHocList.Any())
        {
            <div class="mb-4">
                <h5 class="fw-semibold"><i class="bi bi-calendar3 me-2"></i>Lịch học sắp tới (20 buổi gần nhất)</h5>
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Ngày học</th><th>Thứ</th><th>Giờ</th><th>Phòng</th><th>Lớp</th><th>Giảng viên</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var todayKH = DateOnly.FromDateTime(DateTime.Today); }
                            @foreach (var b in lichHocList)
                            {
                                bool isTodayKH = b.NgayHoc == todayKH;
                                <tr class="@(isTodayKH ? "table-warning" : "")">
                                    <td>
                                        @b.NgayHoc.ToString("dd/MM/yyyy")
                                        @if (isTodayKH) { <span class="badge bg-warning text-dark ms-1">Hôm nay</span> }
                                    </td>
                                    <td><span class="badge bg-secondary" style="font-size:.7rem;">@b.TenThu</span></td>
                                    <td class="small">@b.GioBatDau.ToString("HH:mm")–@b.GioKetThuc.ToString("HH:mm")</td>
                                    <td class="small">@(b.PhongHoc ?? "—")</td>
                                    <td class="small">@b.TenLop</td>
                                    <td class="small text-muted">@(b.TenGiangVien ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.NoiDungChuongTrinh))
        {
            <div class="mb-4">
                <h5 class="fw-semibold"><i class="bi bi-list-check me-2"></i>Nội dung chương trình</h5>
                <div class="bg-light rounded p-3" style="white-space:pre-wrap;">@Model.NoiDungChuongTrinh</div>
            </div>
        }

        @if (Model.LopHocs != null && Model.LopHocs.Any())
        {
            <div class="mb-4">
                <h5 class="fw-semibold"><i class="bi bi-people me-2"></i>Các lớp học đang tuyển sinh</h5>
                <div class="row g-3">
                    @foreach (var lop in Model.LopHocs.Where(l => l.TrangThai == "DangTuyenSinh" || l.TrangThai == "ChuaMo" || l.TrangThai == "DangHoc"))
                    {
                        var lopBadge = lop.TrangThai switch
                        {
                            "DangTuyenSinh" => "bg-success",
                            "ChuaMo" => "bg-secondary",
                            "DangHoc" => "bg-primary",
                            "DaKetThuc" => "bg-dark",
                            _ => "bg-secondary"
                        };
                        var lopText = lop.TrangThai switch
                        {
                            "ChuaMo" => "Chưa mở",
                            "DangTuyenSinh" => "Đang tuyển sinh",
                            "DangHoc" => "Đang học",
                            "DaKetThuc" => "Đã kết thúc",
                            _ => lop.TrangThai
                        };
                        <div class="col-md-6">
                            <div class="card border">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h6 class="fw-bold mb-0">@lop.TenLop</h6>
                                        <span class="badge @lopBadge">@lopText</span>
                                    </div>
                                    @if (lop.NgayKhaiGiang.HasValue)
                                    {
                                        <div class="small text-muted">
                                            <i class="bi bi-calendar me-1"></i>Khai giảng: @lop.NgayKhaiGiang.Value.ToString("dd/MM/yyyy")
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(lop.PhongHoc))
                                    {
                                        <div class="small text-muted">
                                            <i class="bi bi-geo-alt me-1"></i>Phòng: @lop.PhongHoc
                                        </div>
                                    }
                                    <div class="small text-muted">
                                        <i class="bi bi-people me-1"></i>Sĩ số: @lop.DangKys.Count(d => d.TrangThai == "DaDuyet")/@lop.SiSoToiDa
                                    </div>
                                    @if (isHocVien && !daDangKy && (lop.TrangThai == "DangTuyenSinh" || lop.TrangThai == "DangHoc") && lop.DangKys.Count(d => d.TrangThai == "DaDuyet") < lop.SiSoToiDa)
                                    {
                                        <div class="mt-2">
                                            <a asp-controller="DangKy" asp-action="DangKy" asp-route-lopHocId="@lop.Id"
                                               class="btn btn-success btn-sm w-100">
                                                <i class="bi bi-check2-circle me-1"></i>Đăng ký ngay
                                            </a>
                                        </div>
                                    }
                                    else if (isAdmin)
                                    {
                                        <div class="mt-2">
                                            <a asp-controller="LopHoc" asp-action="Details" asp-route-id="@lop.Id"
                                               class="btn btn-outline-primary btn-sm w-100">
                                                <i class="bi bi-eye me-1"></i>Xem lớp
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-light border">
                <i class="bi bi-info-circle me-1"></i>Chưa có lớp học nào cho khóa học này.
                @if (isAdmin)
                {
                    <a asp-controller="LopHoc" asp-action="Create" class="alert-link ms-1">Tạo lớp học mới</a>
                }
            </div>
        }
    </div>
</div>
