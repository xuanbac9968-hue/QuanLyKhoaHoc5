@model QuanLyKhoaHoc5.Web.Models.ViewModels.ChangePasswordViewModel
@{ ViewData["Title"] = "Đổi mật khẩu"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-key me-2 text-primary"></i>Đổi mật khẩu</h4>
</div>
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body p-4">
                <form method="post" asp-action="ChangePassword">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
                    <div class="mb-3">
                        <label asp-for="MatKhauCu" class="form-label fw-semibold"></label>
                        <input asp-for="MatKhauCu" class="form-control" />
                        <span asp-validation-for="MatKhauCu" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="MatKhauMoi" class="form-label fw-semibold"></label>
                        <input asp-for="MatKhauMoi" class="form-control" />
                        <span asp-validation-for="MatKhauMoi" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="XacNhanMatKhau" class="form-label fw-semibold"></label>
                        <input asp-for="XacNhanMatKhau" class="form-control" />
                        <span asp-validation-for="XacNhanMatKhau" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Xác nhận đổi mật khẩu</button>
                    <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-secondary ms-2">Hủy</a>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
