@model QuanLyKhoaHoc5.Web.Models.ViewModels.LoginViewModel
@{ Layout = null; ViewData["Title"] = "Đăng nhập"; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Trung tâm Ngoại ngữ ABC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background: linear-gradient(135deg,#1e3a5f 0%,#0d6efd 100%); min-height: 100vh; display:flex; align-items:center; }
        .login-card { border-radius: 16px; box-shadow: 0 8px 32px rgba(0,0,0,.25); }
        .logo-circle { width: 72px; height: 72px; background: linear-gradient(135deg,#1e3a5f,#0d6efd); border-radius: 50%; display:flex; align-items:center; justify-content:center; }
    </style>
</head>
<body>
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card login-card border-0 p-4">
                <div class="text-center mb-4">
                    <div class="logo-circle mx-auto mb-3">
                        <i class="bi bi-mortarboard-fill text-white fs-2"></i>
                    </div>
                    <h4 class="fw-bold">Trung tâm Ngoại ngữ ABC</h4>
                    <p class="text-muted small">Đăng nhập để tiếp tục</p>
                </div>

                <form method="post" asp-action="Login">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReturnUrl" />
                    <div asp-validation-summary="All" class="alert alert-danger py-2" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="admin@abc.edu.vn" autocomplete="email" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MatKhau" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="MatKhau" class="form-control" id="pwInput" placeholder="••••••••" autocomplete="current-password" />
                            <button type="button" class="btn btn-outline-secondary" onclick="var p=document.getElementById('pwInput');p.type=p.type==='password'?'text':'password'">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="MatKhau" class="text-danger small"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="GhiNho" class="form-check-input" />
                        <label asp-for="GhiNho" class="form-check-label">Ghi nhớ đăng nhập</label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                    </button>
                </form>

                <p class="text-center text-muted small mt-3 mb-0">
                    Quên mật khẩu? Liên hệ Admin để được hỗ trợ.
                </p>
            </div>
        </div>
    </div>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
