@model List<QuanLyKhoaHoc5.Web.Models.ViewModels.DangKyListViewModel>
@{
    ViewData["Title"] = "Đăng ký của tôi";
    var lopMoDangKy = ViewBag.LopMoDangKy as List<QuanLyKhoaHoc5.Web.Models.ViewModels.LopHocListViewModel> ?? new List<QuanLyKhoaHoc5.Web.Models.ViewModels.LopHocListViewModel>();
}

<div class="mb-4">
    <h4 class="mb-0"><i class="bi bi-clipboard-check me-2 text-primary"></i>Đăng ký của tôi</h4>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-list-check me-2"></i>Lịch sử đăng ký
        <span class="badge bg-secondary ms-2">@Model.Count đơn</span>
    </div>
    <div class="card-body p-0">
        @if (Model.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-clipboard fs-1 d-block mb-2"></i>
                Bạn chưa có đơn đăng ký nào
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Lớp học</th>
                            <th>Khóa học</th>
                            <th>Ngôn ngữ</th>
                            <th class="text-center">Ngày đăng ký</th>
                            <th class="text-center">Ngày duyệt</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dk in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@dk.TenLop</td>
                                <td class="small text-muted">@dk.TenKhoaHoc</td>
                                <td>
                                    <span class="badge bg-info-subtle text-info border border-info-subtle">@dk.NgonNgu</span>
                                </td>
                                <td class="text-center small">@dk.NgayDangKy.ToString("dd/MM/yyyy")</td>
                                <td class="text-center small">
                                    @(dk.NgayDuyet.HasValue ? dk.NgayDuyet.Value.ToString("dd/MM/yyyy") : "—")
                                </td>
                                <td class="text-center">
                                    @{
                                        var badge = dk.TrangThai switch {
                                            "DaDuyet" => "bg-success",
                                            "ChoDuyet" => "bg-warning text-dark",
                                            "TuChoi" => "bg-danger",
                                            "DaHuy" => "bg-secondary",
                                            _ => "bg-light text-dark"
                                        };
                                        var ten = dk.TrangThai switch {
                                            "DaDuyet" => "Đã duyệt",
                                            "ChoDuyet" => "Chờ duyệt",
                                            "TuChoi" => "Từ chối",
                                            "DaHuy" => "Đã hủy",
                                            _ => dk.TrangThai
                                        };
                                    }
                                    <span class="badge @badge">@ten</span>
                                    @if (!string.IsNullOrEmpty(dk.LyDoTuChoi))
                                    {
                                        <div class="small text-danger mt-1">
                                            <i class="bi bi-exclamation-circle me-1"></i>@dk.LyDoTuChoi
                                        </div>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (dk.TrangThai == "ChoDuyet")
                                    {
                                        <form asp-controller="DangKy" asp-action="Huy" asp-route-id="@dk.Id"
                                              method="post" onsubmit="return confirm('Bạn có chắc muốn hủy đăng ký này?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-x-circle me-1"></i>Hủy đăng ký
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Lớp đang mở đăng ký -->
@if (lopMoDangKy.Count > 0)
{
    <div class="card">
        <div class="card-header">
            <i class="bi bi-plus-circle me-2 text-success"></i>Lớp học đang tuyển sinh
            <span class="badge bg-success ms-2">@lopMoDangKy.Count lớp</span>
        </div>
        <div class="card-body">
            <div class="row g-3">
                @foreach (var lop in lopMoDangKy)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="border rounded-3 p-3 h-100 d-flex flex-column">
                            <div class="fw-semibold mb-1">@lop.TenLop</div>
                            <div class="small text-muted mb-1">@lop.TenKhoaHoc</div>
                            <div class="d-flex gap-2 mb-2 flex-wrap">
                                <span class="badge bg-info-subtle text-info border border-info-subtle">@lop.NgonNgu</span>
                                @if (lop.NgayKhaiGiang.HasValue)
                                {
                                    <span class="badge bg-light text-dark border small">
                                        <i class="bi bi-calendar me-1"></i>@lop.NgayKhaiGiang.Value.ToString("dd/MM/yyyy")
                                    </span>
                                }
                            </div>
                            <div class="small text-muted mb-2">
                                <i class="bi bi-people me-1"></i>Sĩ số: @lop.SiSoHienTai / @lop.SiSoToiDa
                                @if (!string.IsNullOrEmpty(lop.TenGiangVien))
                                {
                                    <span class="ms-2"><i class="bi bi-person-workspace me-1"></i>@lop.TenGiangVien</span>
                                }
                            </div>
                            <div class="mt-auto">
                                @if (lop.SiSoHienTai < lop.SiSoToiDa)
                                {
                                    <form asp-controller="DangKy" asp-action="DangKy" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="lopHocId" value="@lop.Id" />
                                        <button type="submit" class="btn btn-sm btn-success w-100">
                                            <i class="bi bi-plus-circle me-1"></i>Đăng ký ngay
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-secondary w-100" disabled>
                                        <i class="bi bi-x-circle me-1"></i>Đã đầy chỗ
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
