@model List<QuanLyKhoaHoc5.Web.Models.Entities.GoiYKhoaHoc>
@{ ViewData["Title"] = "Lịch sử gợi ý AI"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>Lịch sử gợi ý AI</h4>
    <a asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-stars me-1"></i>Nhận gợi ý mới</a>
</div>
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Khóa học được gợi ý</th><th>Điểm phù hợp</th><th>Lý do</th><th>Thời gian</th></tr>
                </thead>
                <tbody>
                @foreach (var g in Model) {
                    <tr>
                        <td class="fw-semibold">@g.KhoaHocGoiY?.TenKhoaHoc</td>
                        <td><span class="badge bg-warning text-dark">@(g.DiemPhuHop?.ToString("F0") ?? "-")%</span></td>
                        <td class="small text-muted" style="max-width:300px">@g.LyDoGoiY</td>
                        <td class="small text-muted">@g.NgayGoiY.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                }
                @if (!Model.Any()) { <tr><td colspan="4" class="text-center text-muted py-4">Chưa có lịch sử gợi ý</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>
