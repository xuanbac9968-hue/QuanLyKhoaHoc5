@model List<QuanLyKhoaHoc5.Web.Models.Entities.NguoiDung>
@{ ViewData["Title"] = "Quản lý tài khoản"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-person-lock me-2 text-primary"></i>Quản lý tài khoản</h4>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
        <i class="bi bi-person-plus me-1"></i>Tạo tài khoản
    </button>
</div>
<div class="card">
    <div class="card-header">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm tên, email..." />
            </div>
            <div class="col-md-3">
                <select name="vaiTro" class="form-select">
                    <option value="">-- Tất cả vai trò --</option>
                    @{ string vt = ViewBag.VaiTro ?? ""; }
                    <option value="Admin" selected="@(vt == "Admin" ? "selected" : null)">Admin</option>
                    <option value="GiangVien" selected="@(vt == "GiangVien" ? "selected" : null)">Giảng viên</option>
                    <option value="HocVien" selected="@(vt == "HocVien" ? "selected" : null)">Học viên</option>
                </select>
            </div>
            <div class="col-auto"><button type="submit" class="btn btn-outline-primary"><i class="bi bi-search me-1"></i>Tìm</button></div>
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr><th>Họ tên</th><th>Email</th><th>Vai trò</th><th>Trạng thái</th><th>Ngày tạo</th><th>Thao tác</th></tr>
                </thead>
                <tbody>
                @foreach (var u in Model) {
                    <tr>
                        <td class="fw-semibold">@u.HoTen</td>
                        <td class="small text-muted">@u.Email</td>
                        <td>
                            <form asp-action="DoiRole" asp-route-id="@u.Id" method="post" class="d-inline-flex align-items-center gap-1">
                                @Html.AntiForgeryToken()
                                <select name="vaiTro" class="form-select form-select-sm" style="width:130px;" onchange="this.form.submit()">
                                    <option value="Admin" selected="@(u.VaiTro=="Admin"?"selected":null)">Admin</option>
                                    <option value="GiangVien" selected="@(u.VaiTro=="GiangVien"?"selected":null)">Giảng viên</option>
                                    <option value="HocVien" selected="@(u.VaiTro=="HocVien"?"selected":null)">Học viên</option>
                                </select>
                            </form>
                        </td>
                        <td>
                            @if (u.IsActive) { <span class="badge bg-success">Hoạt động</span> }
                            else { <span class="badge bg-danger">Đã khóa</span> }
                        </td>
                        <td class="small text-muted">@u.NgayTao.ToString("dd/MM/yyyy")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <form method="post" asp-action="KhoaTaiKhoan" asp-route-id="@u.Id">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm @(u.IsActive ? "btn-outline-danger" : "btn-outline-success")" title="@(u.IsActive ? "Khóa tài khoản" : "Mở khóa")">
                                        <i class="bi @(u.IsActive ? "bi-lock" : "bi-unlock")"></i>
                                    </button>
                                </form>
                                <form method="post" asp-action="ResetMatKhau" asp-route-id="@u.Id" onsubmit="return confirm('Reset mật khẩu về mặc định?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-warning" title="Reset mật khẩu"><i class="bi bi-arrow-repeat"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any()) { <tr><td colspan="6" class="text-center text-muted py-4">Không tìm thấy tài khoản</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal tạo tài khoản -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-plus text-primary me-2"></i>Tạo tài khoản mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="TaoTaiKhoan" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Họ tên <span class="text-danger">*</span></label>
                        <input name="hoTen" type="text" class="form-control" required placeholder="Nhập họ tên..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                        <input name="email" type="email" class="form-control" required placeholder="example@email.com" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Số điện thoại</label>
                        <input name="soDienThoai" type="text" class="form-control" placeholder="0912345678" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Vai trò <span class="text-danger">*</span></label>
                        <select name="vaiTro" class="form-select" required>
                            <option value="HocVien">Học viên</option>
                            <option value="GiangVien">Giảng viên</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mật khẩu <span class="text-danger">*</span></label>
                        <input name="matKhau" type="password" class="form-control" required value="Abc@12345" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-person-plus me-1"></i>Tạo tài khoản</button>
                </div>
            </form>
        </div>
    </div>
</div>
