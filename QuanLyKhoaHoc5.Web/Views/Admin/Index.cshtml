@model QuanLyKhoaHoc5.Web.Models.ViewModels.AdminDashboardViewModel
@{ ViewData["Title"] = "Dashboard Admin"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-speedometer2 me-2 text-primary"></i>Tổng quan hệ thống</h4>
    <span class="text-muted small">@DateTime.Now.ToString("dddd, dd/MM/yyyy")</span>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-primary">
            <div class="d-flex justify-content-between align-items-start">
                <div><div class="fs-3 fw-bold">@Model.TongHocVienDangHoc</div><div class="small opacity-75">Học viên đang học</div></div>
                <i class="bi bi-people-fill fs-2 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-success">
            <div class="d-flex justify-content-between align-items-start">
                <div><div class="fs-3 fw-bold">@Model.TongKhoaHocDangMo</div><div class="small opacity-75">Khóa học đang mở</div></div>
                <i class="bi bi-book-fill fs-2 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-warning">
            <div class="d-flex justify-content-between align-items-start">
                <div><div class="fs-3 fw-bold">@Model.TongGiangVien</div><div class="small opacity-75">Giảng viên</div></div>
                <i class="bi bi-person-workspace fs-2 opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-danger">
            <div class="d-flex justify-content-between align-items-start">
                <div><div class="fs-3 fw-bold">@Model.DoanhThuThang.ToString("N0")</div><div class="small opacity-75">Doanh thu tháng (VNĐ)</div></div>
                <i class="bi bi-currency-exchange fs-2 opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<!-- Thanh toán stat row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4">
        <div class="card border-warning shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between py-3">
                <div>
                    <div class="fs-4 fw-bold text-warning">@Model.SoThanhToanChoPheduyet</div>
                    <div class="small text-muted">Thanh toán chờ duyệt</div>
                </div>
                <a asp-controller="ThanhToan" asp-action="Index" asp-route-trangThai="ChoPheduyet" class="btn btn-sm btn-outline-warning">Xem</a>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="card border-success shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between py-3">
                <div>
                    <div class="fs-5 fw-bold text-success">@Model.TongThuThanhToan.ToString("N0") đ</div>
                    <div class="small text-muted">Thu thực tế tháng này (TT)</div>
                </div>
                <a asp-controller="ThanhToan" asp-action="Index" class="btn btn-sm btn-outline-success">Xem</a>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card border-info shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between py-3">
                <div>
                    <div class="small fw-semibold text-info">Quản lý thanh toán</div>
                    <div class="small text-muted">Duyệt/từ chối học phí</div>
                </div>
                <a asp-controller="ThanhToan" asp-action="Index" class="btn btn-sm btn-info text-white">Mở</a>
            </div>
        </div>
    </div>
</div>

<!-- Charts -->
<div class="row g-3 mb-4">
    <div class="col-md-7">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-bar-chart-line me-2 text-primary"></i>Học viên theo khóa học</div>
            <div class="card-body"><canvas id="chartHocVien" height="100"></canvas></div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-graph-up me-2 text-success"></i>Doanh thu 6 tháng (triệu VNĐ)</div>
            <div class="card-body"><canvas id="chartDoanhThu" height="100"></canvas></div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Top 5 khóa học -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-trophy me-2 text-warning"></i>Top 5 khóa học</span>
                <a asp-controller="KhoaHoc" asp-action="Index" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light"><tr><th>#</th><th>Khóa học</th><th>Học viên</th><th>Học phí</th></tr></thead>
                        <tbody>
                        @{ int rank = 1; }
                        @foreach (var k in Model.Top5KhoaHoc)
                        {
                            <tr>
                                <td><span class="badge @(rank == 1 ? "bg-warning text-dark" : rank == 2 ? "bg-secondary" : "bg-light text-dark border")">@rank</span></td>
                                <td>
                                    <a asp-controller="KhoaHoc" asp-action="Details" asp-route-id="@k.Id" class="fw-semibold text-decoration-none">@k.TenKhoaHoc</a>
                                    <br/><small class="text-muted">@k.NgonNgu · @k.TrinhDo</small>
                                </td>
                                <td><span class="badge bg-primary">@k.SoHocVien HV</span></td>
                                <td class="small text-success fw-semibold">@k.HocPhi.ToString("N0")</td>
                            </tr>
                            rank++;
                        }
                        @if (!Model.Top5KhoaHoc.Any()) { <tr><td colspan="4" class="text-center text-muted py-3">Chưa có dữ liệu</td></tr> }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Đăng ký gần đây -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-clipboard-check me-2 text-primary"></i>Đăng ký gần đây</span>
                <a asp-controller="DangKy" asp-action="Index" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light"><tr><th>Học viên</th><th>Lớp</th><th>Trạng thái</th></tr></thead>
                        <tbody>
                        @foreach (var d in Model.DangKyGanDay)
                        {
                            <tr>
                                <td class="small fw-semibold">@d.TenHocVien<br/><span class="text-muted">@d.MaHocVien</span></td>
                                <td class="small">@d.TenLop</td>
                                <td>
                                    @switch(d.TrangThai){
                                        case "ChoDuyet": <span class="badge bg-warning text-dark">Chờ duyệt</span>; break;
                                        case "DaDuyet": <span class="badge bg-success">Đã duyệt</span>; break;
                                        case "TuChoi": <span class="badge bg-danger">Từ chối</span>; break;
                                        default: <span class="badge bg-secondary">@d.TrangThai</span>; break;
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.DangKyGanDay.Any()) { <tr><td colspan="3" class="text-center text-muted py-3">Chưa có đăng ký nào</td></tr> }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
const hocVienLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SoHocVienTheoKhoa.Select(x => x.Label)));
const hocVienData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SoHocVienTheoKhoa.Select(x => x.Value)));
new Chart(document.getElementById('chartHocVien'), {
    type: 'bar',
    data: { labels: hocVienLabels, datasets: [{ label: 'Học viên', data: hocVienData, backgroundColor: '#0d6efd88', borderColor: '#0d6efd', borderWidth: 1, borderRadius: 6 }] },
    options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } }
});

const dtLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DoanhThuTheoThang.Select(x => x.Label)));
const dtData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DoanhThuTheoThang.Select(x => Math.Round(x.Value / 1000000, 2))));
new Chart(document.getElementById('chartDoanhThu'), {
    type: 'line',
    data: { labels: dtLabels, datasets: [{ label: 'Triệu VNĐ', data: dtData, fill: true, backgroundColor: 'rgba(25,135,84,.1)', borderColor: '#198754', tension: .4, pointRadius: 4, pointBackgroundColor: '#198754' }] },
    options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
});
</script>
}
